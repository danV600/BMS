  },
  {
    id: 8,
    title: 'Handover',
    desc: 'Close out the commissioning scope. All punch items resolved, documentation delivered, training completed, and Substantial Completion signed off.',
    sections: [
      { title: 'Close-Out', items: [
        { t: 'Punch list Priority 1 & 2 items resolved', d: 'No outstanding critical items at handover', b: 'crit' },
        { t: 'As-built BMS database backup taken', d: 'Controller DB + SCADA project backup — secure server', b: 'doc' },
        { t: 'O&M manuals and Cx reports delivered', d: 'Hardcopy + digital — signed receipt from facilities team', b: 'doc' },
      ]},
      { title: 'Sign-Off', items: [
        { t: 'Operator training completed and signed', d: 'Min 4 hours — SCADA navigation + alarm response', b: 'doc' },
        { t: 'Passwords changed — credentials handed over', d: 'Default passwords changed — documented in secure handover', b: 'crit' },
        { t: 'Warranty and support contact list provided', d: 'BMS vendor, SCADA vendor, integrator — 24/7 contacts', b: 'doc' },
        { t: 'Substantial Completion certificate signed', d: 'Client + commissioning agent + contractor signatures', b: 'crit' },
      ]},
    ]
  },
];

// ── CHECKED STATE ──
const checked = {};

// ── BUILD TABS ──
const tabsEl = document.getElementById('phaseTabs');
const bodyEl = document.getElementById('drawerBody');

phases.forEach((ph, i) => {
  // tab
  const tab = document.createElement('button');
  tab.className = 'phase-tab' + (i === 0 ? ' active' : '');
  tab.textContent = `Phase ${ph.id}`;
  tab.onclick = () => switchPhase(i);
  tabsEl.appendChild(tab);

  // panel
  const panel = document.createElement('div');
  panel.className = 'phase-panel' + (i === 0 ? ' active' : '');
  panel.id = `phase-panel-${i}`;

  // hero
  const hero = document.createElement('div');
  hero.className = 'phase-hero';
  hero.innerHTML = `
    <div class="phase-num-big">0${ph.id}</div>
    <div class="phase-hero-content">
      <h2>${ph.title}</h2>
      <p>${ph.desc}</p>
    </div>`;
  panel.appendChild(hero);

  // progress
  const progWrap = document.createElement('div');
  progWrap.className = 'phase-progress';
  const allItems = ph.sections.flatMap(s => s.items);
  progWrap.innerHTML = `
    <div class="pp-bar-wrap"><div class="pp-bar" id="ppbar-${i}" style="width:0%"></div></div>
    <div class="pp-label" id="pplabel-${i}">0 / ${allItems.length}</div>`;
  panel.appendChild(progWrap);

  // sections
  ph.sections.forEach(sec => {
    const secEl = document.createElement('div');
    secEl.className = 'cx-section';
    secEl.innerHTML = `<div class="cx-section-title">${sec.title}</div>`;

    sec.items.forEach((item, idx) => {
      const key = `${ph.id}-${sec.title}-${idx}`;
      const itemEl = document.createElement('div');
      itemEl.className = 'cx-item';
      itemEl.id = `item-${key}`;
      itemEl.innerHTML = `
        <div class="cx-check" id="ck-${key}"></div>
        <div class="cx-text">
          <div class="cx-title">${item.t}</div>
          <div class="cx-detail">${item.d}</div>
        </div>
        <span class="cx-badge b-${item.b}">${item.b}</span>`;
      itemEl.onclick = () => toggleItem(key, i, allItems.length);
      secEl.appendChild(itemEl);
    });

    panel.appendChild(secEl);
  });

  bodyEl.appendChild(panel);
});

function switchPhase(idx) {
  document.querySelectorAll('.phase-tab').forEach((t,i) => t.classList.toggle('active', i===idx));
  document.querySelectorAll('.phase-panel').forEach((p,i) => p.classList.toggle('active', i===idx));
}

function toggleItem(key, phaseIdx, total) {
  checked[key] = !checked[key];
  const itemEl = document.getElementById(`item-${key}`);
  const ckEl = document.getElementById(`ck-${key}`);
  itemEl.classList.toggle('done', checked[key]);
  ckEl.textContent = checked[key] ? '✓' : '';

  // update progress bar
  const ph = phases[phaseIdx];
  const allKeys = ph.sections.flatMap((s,si) => s.items.map((_,idx) => `${ph.id}-${s.title}-${idx}`));
  const done = allKeys.filter(k => checked[k]).length;
  const pct = Math.round(done / total * 100);
  document.getElementById(`ppbar-${phaseIdx}`).style.width = pct + '%';
  document.getElementById(`pplabel-${phaseIdx}`).textContent = `${done} / ${total}`;
}

// ── DRAWER TOGGLE ──
let drawerOpen = false;

function toggleDrawer() {
  drawerOpen ? closeDrawer() : openDrawer();
}

function openDrawer() {
  drawerOpen = true;
  document.getElementById('drawer').classList.add('open');
  document.getElementById('overlay').classList.add('show');
  document.getElementById('pullTab').classList.add('open');
  document.querySelector('.pull-tab-arrow').textContent = '▶';
}

function closeDrawer() {
  drawerOpen = false;
  document.getElementById('drawer').classList.remove('open');
  document.getElementById('overlay').classList.remove('show');
  document.getElementById('pullTab').classList.remove('open');
  document.querySelector('.pull-tab-arrow').textContent = '◀';
}
</script>
</body>
</html>
