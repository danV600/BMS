<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>BMS/SCADA — Live Overview</title>
<link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@300;400;500;600;700&family=Fira+Code:wght@300;400;500&display=swap" rel="stylesheet">
<style>
* { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --bg: #070d14;
  --panel: #0b1520;
  --card: #0f1e2e;
  --border: #162840;
  --accent: #00c8ff;
  --green: #00e87a;
  --amber: #ffb300;
  --red: #ff3c5a;
  --text: #b8d4ee;
  --muted: #3d5a78;
  --head: 'Rajdhani', sans-serif;
  --mono: 'Fira Code', monospace;
}

html, body { height: 100%; overflow: hidden; }

body {
  background: var(--bg);
  font-family: var(--head);
  color: var(--text);
  position: relative;
}

/* ── SCADA BACKGROUND GRAPHIC ── */
.scada-bg {
  position: fixed;
  inset: 0;
  background:
    radial-gradient(ellipse 60% 40% at 30% 50%, rgba(0,200,255,0.04) 0%, transparent 70%),
    radial-gradient(ellipse 40% 60% at 75% 30%, rgba(0,232,122,0.03) 0%, transparent 60%);
  z-index: 0;
}

/* grid lines */
.scada-bg::before {
  content: '';
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(rgba(0,200,255,0.04) 1px, transparent 1px),
    linear-gradient(90deg, rgba(0,200,255,0.04) 1px, transparent 1px);
  background-size: 50px 50px;
}

/* ── TOPBAR ── */
.topbar {
  position: fixed;
  top: 0; left: 0; right: 0;
  height: 52px;
  background: rgba(7,13,20,0.95);
  border-bottom: 1px solid var(--border);
  display: flex;
  align-items: center;
  padding: 0 20px;
  gap: 20px;
  z-index: 200;
  backdrop-filter: blur(10px);
}

.topbar-logo {
  font-family: var(--head);
  font-size: 16px;
  font-weight: 700;
  letter-spacing: 0.15em;
  color: #fff;
  text-transform: uppercase;
  display: flex;
  align-items: center;
  gap: 10px;
}

.logo-dot {
  width: 8px; height: 8px;
  border-radius: 50%;
  background: var(--accent);
  box-shadow: 0 0 8px var(--accent);
  animation: pulse 2s infinite;
}

@keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.4} }

.topbar-divider { width: 1px; height: 24px; background: var(--border); }

.topbar-status {
  display: flex;
  align-items: center;
  gap: 16px;
  flex: 1;
}

.status-chip {
  display: flex;
  align-items: center;
  gap: 6px;
  font-family: var(--mono);
  font-size: 10px;
  color: var(--muted);
}

.status-chip .dot {
  width: 6px; height: 6px;
  border-radius: 50%;
  flex-shrink: 0;
}

.dot-green { background: var(--green); box-shadow: 0 0 6px var(--green); }
.dot-amber { background: var(--amber); box-shadow: 0 0 6px var(--amber); animation: pulse 1.5s infinite; }
.dot-red   { background: var(--red);   box-shadow: 0 0 6px var(--red); animation: pulse 0.8s infinite; }

.topbar-time {
  font-family: var(--mono);
  font-size: 11px;
  color: var(--accent);
  margin-left: auto;
}

/* ── MAIN SCADA CANVAS ── */
.scada-canvas {
  position: fixed;
  top: 52px; left: 0; right: 0; bottom: 0;
  z-index: 1;
  overflow: hidden;
  padding: 24px;
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  grid-template-rows: auto 1fr auto;
  gap: 14px;
}

/* system cards */
.sys-card {
  background: rgba(11,21,32,0.85);
  border: 1px solid var(--border);
  border-radius: 6px;
  padding: 14px 16px;
  backdrop-filter: blur(6px);
  position: relative;
  overflow: hidden;
}

.sys-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 2px;
}

.card-green::before { background: linear-gradient(90deg, var(--green), transparent); }
.card-amber::before { background: linear-gradient(90deg, var(--amber), transparent); }
.card-blue::before  { background: linear-gradient(90deg, var(--accent), transparent); }
.card-red::before   { background: linear-gradient(90deg, var(--red), transparent); }

.card-title {
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--muted);
  margin-bottom: 10px;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.card-title span { font-family: var(--mono); font-size: 9px; }

.card-val {
  font-size: 32px;
  font-weight: 700;
  color: #fff;
  line-height: 1;
  margin-bottom: 4px;
}

.card-val small { font-size: 14px; font-weight: 400; color: var(--muted); margin-left: 4px; }

.card-sub {
  font-family: var(--mono);
  font-size: 10px;
  color: var(--muted);
}

/* mini sparkline */
.sparkline {
  margin-top: 10px;
  height: 28px;
  display: flex;
  align-items: flex-end;
  gap: 3px;
}

.spark-bar {
  flex: 1;
  border-radius: 2px 2px 0 0;
  opacity: 0.6;
  transition: opacity 0.2s;
}

.spark-bar:hover { opacity: 1; }

/* pipeline graphic */
.pipeline-card {
  grid-column: 1 / -1;
  background: rgba(11,21,32,0.85);
  border: 1px solid var(--border);
  border-radius: 6px;
  padding: 16px 20px;
  backdrop-filter: blur(6px);
}

.pipeline-title {
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--muted);
  margin-bottom: 14px;
}

.pipeline {
  display: flex;
  align-items: center;
  gap: 0;
  height: 54px;
  position: relative;
}

.pipe-node {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 5px;
  flex-shrink: 0;
}

.pipe-box {
  width: 72px;
  height: 32px;
  border-radius: 4px;
  border: 1px solid;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 9px;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  position: relative;
}

.pipe-box.online  { border-color: var(--green); color: var(--green); background: rgba(0,232,122,0.07); }
.pipe-box.warning { border-color: var(--amber); color: var(--amber); background: rgba(255,179,0,0.07); }
.pipe-box.offline { border-color: var(--red);   color: var(--red);   background: rgba(255,60,90,0.07); }
.pipe-box.idle    { border-color: var(--muted); color: var(--muted); background: transparent; }

.pipe-label {
  font-family: var(--mono);
  font-size: 8px;
  color: var(--muted);
  white-space: nowrap;
}

.pipe-line {
  flex: 1;
  height: 2px;
  position: relative;
  margin-bottom: 14px;
}

.pipe-line-inner {
  height: 100%;
  position: relative;
  overflow: hidden;
}

.pipe-line-inner.active { background: rgba(0,232,122,0.2); }
.pipe-line-inner.active::after {
  content: '';
  position: absolute;
  top: 0; height: 100%;
  width: 40px;
  background: linear-gradient(90deg, transparent, var(--green), transparent);
  animation: flow 1.8s linear infinite;
}

.pipe-line-inner.warn { background: rgba(255,179,0,0.2); }
.pipe-line-inner.warn::after {
  content: '';
  position: absolute;
  top: 0; height: 100%;
  width: 40px;
  background: linear-gradient(90deg, transparent, var(--amber), transparent);
  animation: flow 2.5s linear infinite;
}

@keyframes flow { from{left:-40px} to{left:100%} }

/* alarm log */
.alarm-card {
  grid-column: 1 / 3;
  background: rgba(11,21,32,0.85);
  border: 1px solid var(--border);
  border-radius: 6px;
  padding: 14px 16px;
  backdrop-filter: blur(6px);
}

.alarm-row {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 5px 0;
  border-bottom: 1px solid rgba(22,40,64,0.5);
  font-family: var(--mono);
  font-size: 10px;
}

.alarm-row:last-child { border-bottom: none; }

.alarm-time { color: var(--muted); width: 55px; flex-shrink: 0; }
.alarm-tag {
  padding: 1px 6px;
  border-radius: 2px;
  font-size: 8px;
  font-weight: 600;
  letter-spacing: 0.08em;
  flex-shrink: 0;
}
.tag-crit { background: rgba(255,60,90,0.2); color: var(--red); border: 1px solid rgba(255,60,90,0.4); }
.tag-warn { background: rgba(255,179,0,0.15); color: var(--amber); border: 1px solid rgba(255,179,0,0.3); }
.tag-info { background: rgba(0,200,255,0.12); color: var(--accent); border: 1px solid rgba(0,200,255,0.3); }

.alarm-msg { color: var(--text); flex: 1; }

/* ── PULL TAB TOGGLE ── */
.pull-tab {
  position: fixed;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  z-index: 400;
  cursor: pointer;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4px;
  width: 28px;
  height: 90px;
  background: var(--accent);
  border-radius: 0 6px 6px 0;
  transition: background 0.2s, transform 0.2s, left 0.45s cubic-bezier(.77,0,.18,1);
  box-shadow: 4px 0 20px rgba(0,200,255,0.3);
  writing-mode: vertical-rl;
}

.pull-tab:hover { background: #2dd4ff; }

.pull-tab.open {
  left: 80%;
  background: rgba(15,30,46,0.95);
  border: 1px solid var(--border);
  border-left: none;
  box-shadow: none;
}

.pull-tab-text {
  font-family: var(--head);
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--bg);
  writing-mode: vertical-rl;
  transform: rotate(180deg);
  white-space: nowrap;
}

.pull-tab.open .pull-tab-text { color: var(--accent); }

.pull-tab-arrow {
  font-size: 10px;
  color: var(--bg);
  transition: transform 0.3s;
}

.pull-tab.open .pull-tab-arrow {
  color: var(--accent);
  transform: rotate(180deg);
}

/* ── DRAWER ── */
.drawer {
  position: fixed;
  top: 52px;
  left: 0;
  width: 80%;
  bottom: 0;
  background: rgba(7,13,20,0.97);
  border-right: 1px solid var(--border);
  z-index: 350;
  transform: translateX(-100%);
  transition: transform 0.45s cubic-bezier(.77,0,.18,1);
  display: flex;
  flex-direction: column;
  backdrop-filter: blur(20px);
  overflow: hidden;
}

.drawer.open {
  transform: translateX(0);
}

/* drawer header */
.drawer-header {
  padding: 20px 28px 0;
  border-bottom: 1px solid var(--border);
  flex-shrink: 0;
}

.drawer-title {
  font-size: 20px;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: #fff;
  margin-bottom: 4px;
}

.drawer-subtitle {
  font-family: var(--mono);
  font-size: 10px;
  color: var(--muted);
  margin-bottom: 16px;
}

/* phase tabs */
.phase-tabs {
  display: flex;
  gap: 0;
  overflow-x: auto;
  scrollbar-width: none;
  padding-bottom: 0;
}

.phase-tabs::-webkit-scrollbar { display: none; }

.phase-tab {
  padding: 10px 18px;
  font-family: var(--head);
  font-size: 12px;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--muted);
  cursor: pointer;
  border-bottom: 2px solid transparent;
  white-space: nowrap;
  transition: color 0.2s, border-color 0.2s;
  background: transparent;
  border-top: none;
  border-left: none;
  border-right: none;
  flex-shrink: 0;
}

.phase-tab:hover { color: var(--text); }

.phase-tab.active {
  color: var(--accent);
  border-bottom-color: var(--accent);
}

/* drawer body */
.drawer-body {
  flex: 1;
  overflow-y: auto;
  padding: 24px 28px;
  scrollbar-width: thin;
  scrollbar-color: var(--border) transparent;
}

/* phase panel */
.phase-panel { display: none; animation: fadeUp 0.3s ease; }
.phase-panel.active { display: block; }

@keyframes fadeUp { from{opacity:0;transform:translateY(10px)} to{opacity:1;transform:translateY(0)} }

.phase-hero {
  display: flex;
  align-items: flex-start;
  gap: 20px;
  margin-bottom: 24px;
  padding: 18px 20px;
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 8px;
  position: relative;
  overflow: hidden;
}

.phase-hero::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 2px;
  background: linear-gradient(90deg, var(--accent), transparent);
}

.phase-num-big {
  font-size: 56px;
  font-weight: 700;
  line-height: 1;
  color: rgba(0,200,255,0.12);
  flex-shrink: 0;
  font-family: var(--head);
}

.phase-hero-content h2 {
  font-size: 18px;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: #fff;
  margin-bottom: 6px;
}

.phase-hero-content p {
  font-size: 13px;
  color: var(--muted);
  line-height: 1.6;
  font-family: var(--head);
  font-weight: 400;
}

/* checklist items */
.cx-section {
  margin-bottom: 20px;
}

.cx-section-title {
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--muted);
  margin-bottom: 10px;
  display: flex;
  align-items: center;
  gap: 8px;
}

.cx-section-title::after {
  content: '';
  flex: 1;
  height: 1px;
  background: var(--border);
}

.cx-item {
  display: flex;
  align-items: flex-start;
  gap: 12px;
  padding: 10px 14px;
  border-radius: 6px;
  margin-bottom: 6px;
  border: 1px solid transparent;
  cursor: pointer;
  transition: all 0.15s;
  background: rgba(15,30,46,0.5);
}

.cx-item:hover { border-color: var(--border); background: var(--card); }
.cx-item.done { opacity: 0.5; }

.cx-check {
  width: 16px; height: 16px;
  border: 1px solid var(--muted);
  border-radius: 3px;
  flex-shrink: 0;
  margin-top: 2px;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
  font-size: 10px;
}

.cx-item.done .cx-check {
  border-color: var(--green);
  background: rgba(0,232,122,0.15);
  color: var(--green);
}

.cx-text { flex: 1; }

.cx-title {
  font-size: 13px;
  font-weight: 500;
  color: var(--text);
  line-height: 1.4;
}

.cx-detail {
  font-family: var(--mono);
  font-size: 10px;
  color: var(--muted);
  margin-top: 2px;
  line-height: 1.5;
}

.cx-badge {
  font-family: var(--mono);
  font-size: 8px;
  padding: 2px 6px;
  border-radius: 2px;
  flex-shrink: 0;
  margin-top: 3px;
  border: 1px solid;
  text-transform: uppercase;
  letter-spacing: 0.06em;
}

.b-crit { border-color: rgba(255,60,90,0.5); color: var(--red); }
.b-test { border-color: rgba(0,232,122,0.4); color: var(--green); }
.b-doc  { border-color: rgba(255,179,0,0.4); color: var(--amber); }
.b-ver  { border-color: rgba(0,200,255,0.4); color: var(--accent); }

/* progress mini */
.phase-progress {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 20px;
  padding: 12px 16px;
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 6px;
}

.pp-bar-wrap {
  flex: 1;
  height: 4px;
  background: var(--border);
  border-radius: 2px;
  overflow: hidden;
}

.pp-bar { height: 100%; background: linear-gradient(90deg, var(--accent), var(--green)); border-radius: 2px; transition: width 0.4s; }

.pp-label { font-family: var(--mono); font-size: 10px; color: var(--accent); white-space: nowrap; }

/* overlay */
.overlay {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.5);
  z-index: 300;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.4s;
  top: 52px;
}

.overlay.show { opacity: 1; pointer-events: all; }
</style>
</head>
<body>

<div class="scada-bg"></div>

<!-- TOPBAR -->
<div class="topbar">
  <div class="topbar-logo">
    <div class="logo-dot"></div>
    SCADA / BMS
  </div>
  <div class="topbar-divider"></div>
  <div class="topbar-status">
    <div class="status-chip"><div class="dot dot-green"></div>AHU-01 ONLINE</div>
    <div class="status-chip"><div class="dot dot-green"></div>CHILLER PLANT</div>
    <div class="status-chip"><div class="dot dot-amber"></div>AHU-04 WARNING</div>
    <div class="status-chip"><div class="dot dot-red"></div>PUMP-B FAULT</div>
    <div class="status-chip"><div class="dot dot-green"></div>HISTORIAN OK</div>
  </div>
  <div class="topbar-time" id="clock">--:--:--</div>
</div>

<!-- SCADA CANVAS -->
<div class="scada-canvas">

  <!-- Row 1: stat cards -->
  <div class="sys-card card-blue">
    <div class="card-title">Supply Air Temp <span class="dot dot-green"></span></div>
    <div class="card-val">18.4<small>°C</small></div>
    <div class="card-sub">Setpoint 18.0°C · Δ +0.4</div>
    <div class="sparkline" id="sp1"></div>
  </div>

  <div class="sys-card card-green">
    <div class="card-title">Chilled Water Flow <span class="dot dot-green"></span></div>
    <div class="card-val">142<small>L/s</small></div>
    <div class="card-sub">Design 150 L/s · 94.7%</div>
    <div class="sparkline" id="sp2"></div>
  </div>

  <div class="sys-card card-amber">
    <div class="card-title">BMS Active Alarms <span class="dot dot-amber"></span></div>
    <div class="card-val">3<small>active</small></div>
    <div class="card-sub">1 Critical · 2 Warning</div>
    <div class="sparkline" id="sp3"></div>
  </div>

  <!-- Row 2: pipeline -->
  <div class="pipeline-card">
    <div class="pipeline-title">System Integration Flow — BMS ↔ SCADA</div>
    <div class="pipeline">
      <div class="pipe-node"><div class="pipe-box online">Field I/O</div><div class="pipe-label">Controllers</div></div>
      <div class="pipe-line"><div class="pipe-line-inner active"></div></div>
      <div class="pipe-node"><div class="pipe-box online">BACnet/IP</div><div class="pipe-label">Protocol</div></div>
      <div class="pipe-line"><div class="pipe-line-inner active"></div></div>
      <div class="pipe-node"><div class="pipe-box online">BMS Core</div><div class="pipe-label">Controllers</div></div>
      <div class="pipe-line"><div class="pipe-line-inner active"></div></div>
      <div class="pipe-node"><div class="pipe-box online">OPC-UA</div><div class="pipe-label">Gateway</div></div>
      <div class="pipe-line"><div class="pipe-line-inner warn"></div></div>
      <div class="pipe-node"><div class="pipe-box warning">SCADA Srv</div><div class="pipe-label">Ignition</div></div>
      <div class="pipe-line"><div class="pipe-line-inner active"></div></div>
      <div class="pipe-node"><div class="pipe-box online">Historian</div><div class="pipe-label">OSIsoft PI</div></div>
      <div class="pipe-line"><div class="pipe-line-inner active"></div></div>
      <div class="pipe-node"><div class="pipe-box online">HMI</div><div class="pipe-label">Operator</div></div>
    </div>
  </div>

  <!-- Row 3: alarms + extra card -->
  <div class="alarm-card">
    <div class="card-title" style="margin-bottom:10px">Recent Alarm Log</div>
    <div class="alarm-row"><span class="alarm-time">09:41:22</span><span class="alarm-tag tag-crit">CRIT</span><span class="alarm-msg">PUMP-B — Low differential pressure fault</span></div>
    <div class="alarm-row"><span class="alarm-time">09:38:05</span><span class="alarm-tag tag-warn">WARN</span><span class="alarm-msg">AHU-04 — Supply air temp high limit exceeded</span></div>
    <div class="alarm-row"><span class="alarm-time">09:22:44</span><span class="alarm-tag tag-warn">WARN</span><span class="alarm-msg">SCADA Server — OPC-UA polling latency >200ms</span></div>
    <div class="alarm-row"><span class="alarm-time">08:55:10</span><span class="alarm-tag tag-info">INFO</span><span class="alarm-msg">Historian — Daily backup completed successfully</span></div>
    <div class="alarm-row"><span class="alarm-time">08:12:33</span><span class="alarm-tag tag-info">INFO</span><span class="alarm-msg">NTP sync — All controllers synchronized</span></div>
  </div>

  <div class="sys-card card-red">
    <div class="card-title">Energy Today <span class="dot dot-green"></span></div>
    <div class="card-val">1,847<small>kWh</small></div>
    <div class="card-sub">vs yesterday 1,920 kWh · ↓3.8%</div>
    <div class="sparkline" id="sp4"></div>
  </div>

</div>

<!-- OVERLAY -->
<div class="overlay" id="overlay" onclick="closeDrawer()"></div>

<!-- DRAWER -->
<div class="drawer" id="drawer">
  <div class="drawer-header">
    <div class="drawer-title">Commissioning Protocol</div>
    <div class="drawer-subtitle">BMS / SCADA Integration — Field Checklist // Select Phase</div>
    <div class="phase-tabs" id="phaseTabs"></div>
  </div>
  <div class="drawer-body" id="drawerBody"></div>
</div>

<!-- PULL TAB -->
<div class="pull-tab" id="pullTab" onclick="toggleDrawer()">
  <span class="pull-tab-arrow">◀</span>
  <span class="pull-tab-text">Cx Phases</span>
</div>

<script>
// ── CLOCK ──
function updateClock() {
  const now = new Date();
  document.getElementById('clock').textContent =
    now.toLocaleTimeString('en-GB', {hour:'2-digit', minute:'2-digit', second:'2-digit'});
}
setInterval(updateClock, 1000);
updateClock();

// ── SPARKLINES ──
function makeSpark(id, color) {
  const el = document.getElementById(id);
  if (!el) return;
  const vals = Array.from({length:14}, () => Math.random());
  const max = Math.max(...vals);
  vals.forEach(v => {
    const b = document.createElement('div');
    b.className = 'spark-bar';
    b.style.height = (v / max * 100) + '%';
    b.style.background = color;
    el.appendChild(b);
  });
}
makeSpark('sp1','#00c8ff');
makeSpark('sp2','#00e87a');
makeSpark('sp3','#ffb300');
makeSpark('sp4','#ff3c5a');

// ── PHASE DATA ──
